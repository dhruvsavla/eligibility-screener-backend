# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed.

# Required: Anthropic API key for Claude Sonnet criteria extraction and rationale generation
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./eligibility.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (JSON array format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# External tool paths
SYNTHEA_JAR_PATH=backend/synthea/synthea.jar
OMOP_DIR=backend/omop
